BOT_TOKEN=your_bot_token_here
BASE_DOWNLOAD_LINK=http://your-server-ip:8000
WHITELIST_USERS=123456789,987654321
# Route yt-dlp through Cloudflare Warp (127.0.0.1:40000). Requires warp-cli
# to be installed + connected on the VPS. Defaults to false.
USE_WARP=false
# Minimum free disk space (in MB) required on the downloads/ filesystem
# before starting a download. Below this threshold the bot refuses with a
# friendly `disk_error` message instead of letting yt-dlp hit ENOSPC mid
# download. Default 1024 MB (1 GB) covers typical 1080p mux peaks on a small
# VPS. Set to 0 to disable the pre-flight check entirely (debug only; an
# ENOSPC mid-download is then your problem). Missing/empty/non-numeric
# values gracefully fall back to the default — config errors never crash
# bot startup.
MIN_DISK_FREE_MB=1024
# Telegram user IDs (comma-separated) allowed to upload cookies via /cookies.
# Cookies are sensitive auth tokens (they contain session cookies for a
# signed-in YouTube account). On a shared bot you usually want only the
# operator(s) to upload them. Exit semantics:
#   * ADMIN_USERS unset/empty (default): every whitelisted user keeps the
#     legacy cookie-upload path. The bot behaves exactly as before.
#   * ADMIN_USERS set: only listed uids can trigger /cookies. Other
#     whitelisted users get a clear "🔒 admin-only" rejection and the
#     conversation exits cleanly (next text message routes to download).
# ADMIN_USERS=123456789
# Number of most-recent YouTube comments to fetch + display per download in
# the format-choice screen. Optional opt-in — default is OFF (0) so an
# upgrade is non-disruptive. Range: 0 (off) ... 20 (max-safe). Above 20 is
# silently clamped down to 20 inside Config.MAX_COMMENTS; below 0 is
# silently treated as 0. YouTube aggressively rate-limits / IP-blocks
# callers that hammer the Innertube `/next` comment endpoint, so keep this
# small. Operators cannot enable this via CLI / menu — toggle only by
# editing `.env` (locally) or the GitHub Secrets → `MAX_COMMENTS`
# variable (in CI/CD deploys). Comment fetching adds ~1-2 s to the
# format-choice fetch but is already inside run_in_executor so the bot's
# event loop is not blocked.
MAX_COMMENTS=0
# -----------------------------------------------------------------------------
# Native HTTPS for the built-in file server (optional, opt-in).
#
# Set BOTH of the variables below to enable TLS termination inside the bot
# itself — no reverse proxy required. The aiohttp FileServer will accept
# HTTPS connections on the port derived from BASE_DOWNLOAD_LINK (e.g.
# `https://mydomain.com:8000` → port 8000, TLS on the same socket).
#
# Behaviour matrix:
#   * Both empty (default): plain HTTP. Pre-existing behaviour.
#   * Both set + readable + loadable: HTTPS using those files.
#   * Partial / missing / unreadable: bot refuses to start with a
#     CRITICAL log line — never silently falls back to HTTP.
#
# IMPORTANT: Binding to a port < 1024 (HTTPS default 443) requires root
# or `setcap 'cap_net_bind_service=+ep' $(readlink -f $(which python))`.
# Most operators running native SSL stay on 8000/8443 and put Caddy/Nginx
# in front ONLY if they want port 443.
#
# IMPORTANT: Certificate renewal does NOT auto-reload. After `certbot
# renew` (or a Let's Encrypt scheduled run) you must restart the bot
# service to pick up the new cert. Recommended:
#   certbot renew --deploy-hook "systemctl restart telegramytbot"
#
# SSL_CERT_FILE=/etc/letsencrypt/live/mydomain.com/fullchain.pem
# SSL_KEY_FILE=/etc/letsencrypt/live/mydomain.com/privkey.pem