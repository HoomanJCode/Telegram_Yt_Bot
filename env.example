BOT_TOKEN=your_bot_token_here
BASE_DOWNLOAD_LINK=http://your-server-ip:8000
WHITELIST_USERS=123456789,987654321
# Route yt-dlp through Cloudflare Warp (127.0.0.1:40000). Requires warp-cli
# to be installed + connected on the VPS. Defaults to false.
USE_WARP=false
# Minimum free disk space (in MB) required on the downloads/ filesystem
# before starting a download. Below this threshold the bot refuses with a
# friendly `disk_error` message instead of letting yt-dlp hit ENOSPC mid
# download. Default 1024 MB (1 GB) covers typical 1080p mux peaks on a small
# VPS. Set to 0 to disable the pre-flight check entirely (debug only; an
# ENOSPC mid-download is then your problem). Missing/empty/non-numeric
# values gracefully fall back to the default — config errors never crash
# bot startup.
MIN_DISK_FREE_MB=1024